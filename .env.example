# Environment Variables for CeyLaw MVP
# Rename this file to .env.local and fill in the values

# Astra DB Configuration (Generous Free Tier for Vectors)
ASTRA_DB_API_ENDPOINT=https://your-database-id-region.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:your-token-here

# AI Provider Keys (Gemini 2.5 Flash recommended for cost-efficiency)
GEMINI_API_KEY=your-gemini-api-key

# Internal App Secrets
NEXTAUTH_SECRET=generate-a-random-secret
